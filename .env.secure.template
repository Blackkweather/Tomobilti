# ShareWheelz UK Platform - Secure Environment Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/sharewheelz

# JWT Security
JWT_SECRET=your_secure_jwt_secret_here_minimum_64_characters
JWT_EXPIRES_IN=7d

# Demo User Credentials (for development only)
DEMO_USER_EMAIL=demo@sharewheelz.uk
DEMO_USER2_EMAIL=demo2@sharewheelz.uk
DEMO_USER_PASSWORD=SecureDemo123!

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
APPLE_CLIENT_ID=your_apple_client_id_here
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here

# Frontend OAuth Configuration
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here
REACT_APP_FACEBOOK_APP_ID=your_facebook_app_id_here
REACT_APP_APPLE_CLIENT_ID=your_apple_client_id_here
REACT_APP_MICROSOFT_CLIENT_ID=your_microsoft_client_id_here

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# OpenAI Configuration (Optional)
OPENAI_API_KEY=sk_your_openai_api_key_here

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379

# Application Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here_minimum_32_characters
CSRF_SECRET=your_csrf_secret_here_minimum_32_characters

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp
IMAGE_QUALITY=85
THUMBNAIL_SIZE=300
RESPONSIVE_SIZES=400,800,1200,1600

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info

# SSL Configuration
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Mock Services (for development)
ENABLE_MOCK_SERVICES=true