NODE_ENV=test
PORT=5001
FRONTEND_URL=http://localhost:5001
DATABASE_URL=file:./test.db
JWT_SECRET=test-jwt-secret-do-not-use-in-production
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=4
